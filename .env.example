# Splynx Cloud tenant base URL (no trailing slash)
SPLYNX_BASE_URL=https://your-tenant.splynx.com

# The single Splynx login that gets admin UI access. Other logins get tech UI only.
ADMIN_LOGIN=david

# Anthropic API key for the summarize and rate Claude calls.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-sonnet-4-6).
CLAUDE_MODEL=claude-sonnet-4-6

# Target WhatsApp group JID. Leave blank until after the QR onboarding —
# then list available groups in the admin panel and copy the JID here.
WHATSAPP_GROUP_JID=

# 32+ random bytes, hex-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Persistent data directory (sqlite db, photos archive, baileys auth state).
# Inside the container this is /data, mounted from the named docker volume.
DATA_DIR=/data

# Public URL where the PWA is reachable (Coolify will set this when SSL is provisioned).
PUBLIC_BASE_URL=

# Set to true to log Claude prompts/responses to stdout (do not enable in production).
AI_DEBUG_LOG=false
