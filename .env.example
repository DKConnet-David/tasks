# Splynx Cloud tenant base URL (no trailing slash)
SPLYNX_BASE_URL=https://your-tenant.splynx.com

# The single admin login + password for the app.
# Tech provisioning (multiple users) lands later as a `techs` table.
ADMIN_LOGIN=david
ADMIN_PASSWORD=change-me-to-something-strong

# Anthropic API key for the summarize and rate Claude calls.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-sonnet-4-6).
CLAUDE_MODEL=claude-sonnet-4-6

# Target WhatsApp group JID. Leave blank until after the QR onboarding —
# then list available groups in the admin panel and copy the JID here.
WHATSAPP_GROUP_JID=

# 32+ random bytes, hex-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Persistent data directory (sqlite db, photos archive, baileys auth state).
# Inside the container this is /data, mounted from the named docker volume.
DATA_DIR=/data

# Public URL where the PWA is reachable (Coolify will set this when SSL is provisioned).
PUBLIC_BASE_URL=

# Set to true to log Claude prompts/responses to stdout (do not enable in production).
AI_DEBUG_LOG=false

# ----------------------------------------------------------------------
# Caddy SSL (Let's Encrypt via DNS-01 against SimpleDNS Plus)
# ----------------------------------------------------------------------
# Caddy publishes ACME challenge TXT records to your SimpleDNS Plus server
# via TSIG-signed RFC 2136 dynamic updates. Set these once on first deploy.

# Name of the TSIG key configured in SimpleDNS Plus
# (Tools → Options → Updates → TSIG keys)
ACME_TSIG_KEYNAME=caddy-acme-key

# The base64 secret that SimpleDNS Plus shows after generating the key.
# Treat as a password — gives whoever holds it the ability to write TXT
# records under whatever zone scope you allowed.
ACME_TSIG_SECRET=

# Hostname or IP of the SimpleDNS Plus server, reachable from the Coolify
# host on UDP/53 (and TCP/53 as a fallback).
ACME_DNS_SERVER=

# Email Let's Encrypt uses for expiry-warning notifications.
ACME_EMAIL=david@dkconnect.co.za
